# =============================================================================
# Domain Cleanup Automation — Environment Configuration
# Copy to .env and fill in real values.
# =============================================================================

# -- Run behaviour ------------------------------------------------------------
DRY_RUN=true
LOG_LEVEL=INFO
OUTPUT_DIR=/output

# -- Source database 1 (Linkstatus Blauwe Monsters) ---------------------------
SOURCE_DB1_HOST=linkstatus.nl
SOURCE_DB1_PORT=3306
SOURCE_DB1_NAME=linkstatus_blauwemonsters
SOURCE_DB1_USER=
SOURCE_DB1_PASSWORD=

# -- Source database 2 (Linkstatus Brand New Media) ---------------------------
SOURCE_DB2_HOST=linkstatus.nl
SOURCE_DB2_PORT=3306
SOURCE_DB2_NAME=linkstatus_brandnewmedia
SOURCE_DB2_USER=
SOURCE_DB2_PASSWORD=

# -- Local audit / logging database (hosted on mysql_db) ----------------------
AUDIT_DB_HOST=mysql_db
AUDIT_DB_PORT=3306
AUDIT_DB_NAME=domain_audit
AUDIT_DB_USER=
AUDIT_DB_PASSWORD=

# -- HostingIndustries account 1 (Blauwe Monsters) ----------------------------
HI_ACCOUNT1_USERNAME=
HI_ACCOUNT1_PASSWORD=
HI_ACCOUNT1_NAME=blauwemonsters

# -- HostingIndustries account 2 (Brand New Media) ----------------------------
HI_ACCOUNT2_USERNAME=
HI_ACCOUNT2_PASSWORD=
HI_ACCOUNT2_NAME=brandnewmedia

# -- Dashboard ----------------------------------------------------------------
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=changeme
DASHBOARD_PORT=8088

# -- Mailgun ------------------------------------------------------------------
ENABLE_EMAIL_SEND=false
MAILGUN_API_KEY=
MAILGUN_DOMAIN=bnm-server.org
MAILGUN_FROM=noreply@bnm-server.org
MAILGUN_API_URL=https://api.eu.mailgun.net

# -- Google Sheets via n8n (zero config — uses existing BM OAUTH2) -----------
ENABLE_SHEETS_SYNC=false
N8N_SHEETS_WEBHOOK_URL=https://n8n.bnm-server.org/webhook/domain-cleanup-sheets

# -- Business rules -----------------------------------------------------------
UNUSABLE_DOMAIN_STATUSES=Quarantaine,Expiry,Expired,Suspended
AFFECTED_ORDER_STATUSES=failed,pending,processing
EXPIRED_LABEL_ID=79

# -- Timeouts / retries -------------------------------------------------------
HI_REQUEST_TIMEOUT=30
HI_MAX_RETRIES=3
